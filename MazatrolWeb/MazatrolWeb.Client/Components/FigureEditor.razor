@namespace MazatrolWeb.Client.Components
@inject MazatrolAppService AppService
@inject MazatrolSessionState Session
@inject ProgramEditorService Editor
@inject FileDownloadService Downloads

@if (Block is null)
{
    <p class="text-muted small">Select a unit or figure to edit parameters.</p>
}
else
{
    <div class="figure-editor">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">
                @Block.UnitName
                <span class="text-muted">0x@(Block.UnitAddress.ToString("X"))</span>
            </h6>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-danger" @onclick="() => Edit(UnitEditAction.Delete)">Delete</button>
                <button class="btn btn-outline-secondary" @onclick="() => Edit(UnitEditAction.Duplicate)">Duplicate</button>
                <button class="btn btn-outline-info" @onclick="() => Edit(UnitEditAction.Export)">Export</button>
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown">Insert</button>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><button class="dropdown-item" @onclick="() => Edit(UnitEditAction.InsertLin)">LIN</button></li>
                        <li><button class="dropdown-item" @onclick="() => Edit(UnitEditAction.InsertTpr)">TPR</button></li>
                        <li><button class="dropdown-item" @onclick="() => Edit(UnitEditAction.InsertFacing)">FACING</button></li>
                    </ul>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-1 small">@_error</div>
        }

        <table class="table table-sm table-dark table-striped mb-0">
            <thead><tr><th>Parameter</th><th>Value</th><th></th></tr></thead>
            <tbody>
                @foreach (var param in Block.Parameters.Where(p => p.Name is not ""))
                {
                    <tr>
                        <td>@param.Name</td>
                        <td>
                            @if (param.IsEditable)
                            {
                                <input type="text"
                                       class="form-control form-control-sm"
                                       value="@param.DisplayValue"
                                       @onchange="e => QueueEdit(param, e.Value?.ToString())" />
                            }
                            else
                            {
                                <span class="text-muted">@param.DisplayValue</span>
                            }
                        </td>
                        <td class="text-muted small">@param.ParamType</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public ProgramBlock? Block { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private MazatrolParser Parser => AppService.Parser;
    private string? _error;

    private async Task QueueEdit(Services.ParameterValue param, string? value)
    {
        if (Session.FileData is null || string.IsNullOrWhiteSpace(value))
            return;

        try
        {
            var data = Session.FileData.ToArray();
            Parser.WriteParameter(data, param.FileOffset, param.ParamType, value);
            var blocks = AppService.Reparse(data);
            Session.UpdateData(data, blocks);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Edit(UnitEditAction action)
    {
        _error = null;
        if (Session.FileData is null || Block is null)
            return;

        try
        {
            var header = Block.IsUnitHeader ? Block : FindParentHeader(Block);
            if (header is null)
                throw new InvalidOperationException("Could not locate unit header.");

            var data = Session.FileData.ToArray();
            var updated = Editor.Apply(data, header.UnitAddress, action, header.UnitName, out var exported);

            if (exported is not null)
            {
                await Downloads.DownloadBytesAsync(
                    $"{Session.FileName}_{header.UnitName}.unit", exported);
            }

            var blocks = AppService.Reparse(updated);
            Session.UpdateData(updated, blocks);
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private ProgramBlock? FindParentHeader(ProgramBlock block)
    {
        ProgramBlock? lastHeader = null;
        foreach (var b in Session.Blocks)
        {
            if (b.IsUnitHeader)
                lastHeader = b;
            if (b.Id == block.Id)
                return lastHeader;
        }
        return block.IsUnitHeader ? block : null;
    }
}
