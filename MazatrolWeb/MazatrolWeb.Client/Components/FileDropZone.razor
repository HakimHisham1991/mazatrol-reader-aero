@namespace MazatrolWeb.Client.Components
@inject MazatrolSessionState Session
@implements IDisposable

<div class="drop-zone">
    <label class="btn btn-primary mb-0 @(Session.IsLoading ? "disabled" : "")">
        Open Mazatrol program…
        <InputFile OnChange="OnFileSelected"
                   accept=".pbg,.pbf,.pbd,.pbe,.pbm,.mzk,.t6m,.m6m,.maz,.html,.htm"
                   class="d-none"
                   disabled="@Session.IsLoading" />
    </label>
    <span class="text-muted ms-2 small">Supported: .PBG, .PBF, .HTML (export), …</span>
    @if (!string.IsNullOrEmpty(_fileName))
    {
        <span class="badge bg-secondary ms-2">@_fileName</span>
    }
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-2 py-1 small mb-0">@_error</div>
    }
</div>

@code {
    [Parameter] public EventCallback<(byte[] Data, string FileName)> OnFileLoaded { get; set; }

    private string? _fileName;
    private string? _error;

    protected override void OnInitialized() => Session.OnChanged += StateHasChanged;

    public void Dispose() => Session.OnChanged -= StateHasChanged;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        var file = e.File;
        if (file is null) return;

        if (!MazatrolConstants.SupportedExtensions.Contains(Path.GetExtension(file.Name)))
        {
            _error = "Unsupported file type.";
            return;
        }

        Session.BeginLoading("Reading file…");
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            var buffer = new byte[81920];
            var totalBytes = file.Size > 0 ? file.Size : (long?)null;
            long bytesRead = 0;

            int count;
            while ((count = await stream.ReadAsync(buffer)) > 0)
            {
                ms.Write(buffer, 0, count);
                bytesRead += count;
                if (totalBytes is > 0)
                {
                    var percent = (int)(bytesRead * 30 / totalBytes.Value);
                    Session.SetLoadingProgress(percent, "Reading file…");
                }
                else
                {
                    Session.SetLoadingProgress(15, "Reading file…");
                }
            }

            _fileName = file.Name;
            Session.SetLoadingProgress(35, "Opening program…");
            await OnFileLoaded.InvokeAsync((ms.ToArray(), file.Name));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Session.EndLoading();
        }
    }
}

<style>
    .drop-zone {
        border: 2px dashed #555;
        border-radius: 8px;
        padding: 1rem;
    }
    .drop-zone.drag-over { border-color: #0d6efd; }
</style>
